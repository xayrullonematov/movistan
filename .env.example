# =============================================================================
# AI Engineering Room — Environment Variables
# Copy this to .env and fill in your values
# =============================================================================

# --- Database ---
# Local SQLite file (for single-server VPS deployment)
DATABASE_URL=file:./data/production.db
# Or use Turso (LibSQL) for managed hosting:
# DATABASE_URL=libsql://your-db.turso.io
# LIBSQL_AUTH_TOKEN=your-token

# --- LLM Provider ---
# Options: "bedrock" or leave empty for OpenAI-compatible API
# For the Qwen Cloud Global AI Hackathon submission, leave LLM_PROVIDER empty
# (the OpenAI-compatible path is used to talk to Qwen via DashScope).
LLM_PROVIDER=

# OpenAI-compatible config (used when LLM_PROVIDER is empty).
# --- Qwen Cloud (DashScope, OpenAI-compatible mode) ---
# Get your API key from https://bailian.console.alibabacloud.com (international)
# or the regional Model Studio console for your account.
LLM_API_KEY=sk-your-dashscope-api-key
# Singapore / International endpoint (default for the global hackathon):
LLM_API_ENDPOINT=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Alternative regional endpoints:
#   US (Virginia):    https://dashscope-us.aliyuncs.com/compatible-mode/v1
#   China (Beijing):  https://dashscope.aliyuncs.com/compatible-mode/v1
#   Hong Kong:        https://cn-hongkong.dashscope.aliyuncs.com/compatible-mode/v1
# Note: API keys are region-scoped and NOT interchangeable across endpoints.

# --- Model Configuration ---
# Qwen models (recommended for the hackathon submission):
LLM_MODEL=qwen3-max
LLM_MODEL_CRITIQUE_TIER=qwen3-coder-plus
LLM_MODEL_SUMMARY_TIER=qwen-turbo

# Bedrock models (if LLM_PROVIDER=bedrock):
# LLM_MODEL=us.anthropic.claude-sonnet-4-6
# LLM_MODEL_CRITIQUE_TIER=us.anthropic.claude-haiku-4-5-20251001-v1:0
# LLM_MODEL_SUMMARY_TIER=us.anthropic.claude-haiku-4-5-20251001-v1:0

# OpenAI models (if using OpenAI directly):
# LLM_MODEL=gpt-4o
# LLM_MODEL_CRITIQUE_TIER=gpt-4o-mini
# LLM_MODEL_SUMMARY_TIER=gpt-4o-mini

# --- AWS (required if LLM_PROVIDER=bedrock) ---
# Leave empty unless you're using the Bedrock backend. Never commit real keys.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Or use IAM instance role (leave keys empty on EC2)

# --- GitHub (optional, proposal-stage tool grounding) ---
# When set, the github-fetcher sends this as a bearer token to raise the
# unauthenticated rate limit. Leave empty for public-repo browsing — the
# unauthenticated quota is enough for low-volume use. Private-repo OAuth is
# out of scope for Phase 1.
GITHUB_TOKEN=

# --- App ---
NODE_ENV=production
PORT=3000

# --- Demo Password Gate ---
# When set, visitors must enter this password before accessing the app.
# Leave empty to disable the gate.
DEMO_PASSWORD=
