DATABASE_URL="file:./dev.db"

# === LLM provider selection ===
# Default: OpenAI-compatible HTTP at LLM_API_ENDPOINT with Bearer LLM_API_KEY.
# Set LLM_PROVIDER=bedrock to use AWS Bedrock (ignores LLM_API_KEY/ENDPOINT).
# LLM_PROVIDER=bedrock

# === OpenAI-compatible (default) ===
LLM_API_KEY="your-api-key-here"
LLM_API_ENDPOINT="https://api.openai.com/v1"
LLM_MODEL="gpt-4o"
LLM_MODEL_SUMMARY_TIER="gpt-4o-mini"
LLM_MODEL_CRITIQUE_TIER="gpt-4o-mini"

# === AWS Bedrock (when LLM_PROVIDER=bedrock) ===
# Credentials resolve via the standard AWS chain: env vars (below) →
# ~/.aws/credentials → IAM role. Region defaults to us-east-1.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# Bedrock model IDs (override the LLM_MODEL* lines above when using Bedrock):
# LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
# LLM_MODEL_CRITIQUE_TIER=anthropic.claude-3-5-haiku-20241022-v1:0
# LLM_MODEL_SUMMARY_TIER=anthropic.claude-3-5-haiku-20241022-v1:0

DEFAULT_TOKEN_BUDGET=500000
MAX_RETRIES=3
